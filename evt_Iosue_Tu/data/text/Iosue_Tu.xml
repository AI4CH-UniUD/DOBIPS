	<text>
		<body>
			<head>
				<pb facs="data/images/single/Tu_271r.jpeg" n="Tu_271r"/>
				<lb n="[Tu_271r]"/>
				<lb/>
				<app>
					<lem wit="#Tu" rendition="#CU #red">INCiPiunt CAPituLa</lem>
					<rdg wit="#A" type="omission" cause="unknown"/>
				</app>
			</head>

			<list>
				<item n="1">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>1.1 et factum
								est</citedRange></bibl><num>I</num></ref>
					<title>Promittit deus iosue dicens <q type="spoken">sicut fui cum <app>
								<lem>moysen</lem>
								<rdg wit="#A" type="minor" cause="grammatical">moyse</rdg>
							</app> ero et tecum</q></title></item>
				<item n="2">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>1.10
								praecepitque Iosue</citedRange></bibl><num>II</num></ref>
					<title> Iubet iosue <app>
							<lem>populo</lem>
							<rdg wit="#Tu" varSeq="1" type="minor" cause="grammatical"
								rend="erasure" cert="low">populum</rdg>
							<rdg wit="#Tu" varSeq="2" type="lem" cause="correction"
								rend="overstrike" hand="#m">populo</rdg>
						</app> ut praeparet sibi cibaria<app>
							<lem>et</lem>
							<rdg wit="#A" type="maior" subtype="adiaphoric" cause="grammatical"
								>ut</rdg>
						</app> transeant iordanem <app>
							<lem>ammonens etiam rubenetas et gadditas et dimidiam tribum manasse ut
								conlocantes familias suas in terram quam <app>
									<lem wit="#Tu">tradiderat</lem>
									<rdg wit="#Tu" varSeq="1" type="minor" cause="grammatical"
										rend="subpunctuated">tradiderit</rdg>
									<rdg wit="#Tu" varSeq="2" type="lem" cause="correction"
										hand="#m" rend="above">tradiderat</rdg>
								</app> eis moyses et praecederent armati sicut moyse
								promiserant</lem>
							<rdg wit="#A" type="omission" cause="seriesA"/>
						</app></title>
				</item>
				<item n="3">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>2.1 misit
								igitur Iosue</citedRange></bibl><num>III</num></ref>
					<title><app>
							<lem>Mittuntur a iosue de sethim duo uiri exploratores </lem>
							<rdg wit="#A" type="substantive" subtype="adiaphoric" cause="seriesA"
								>Destinantur exploratores a iosue</rdg>
						</app> in hiericho <app>
							<lem>quos recipiens domo raab meretrix celabit</lem>
							<rdg wit="#A" type="omssion" cause="seriesA"/>
						</app></title>
				</item>
				<item n="4">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>3.7 dixitque
								Dominus ad Iosue</citedRange></bibl><num>IIII</num></ref>
					<title><app>
							<lem>Dixit</lem>
							<rdg wit="#A" type="substantive" subtype="adiaphoric" cause="seriesA"
								>promittit</rdg>
						</app> dominus <app>
							<lem>ad</lem>
							<rdg wit="#A" type="omission" cause="seriesA"/>
						</app> iosue <app>
							<lem/>
							<rdg wit="#A" type="addition" cause="seriesA">dicens</rdg>
						</app>
						<q type="spoken">hodie incipiam exaltare te coram omni israhel ut sciant
							quia sicut fui cum moyse <app>
								<lem/>
								<rdg wit="#Tu" varSeq="1" type="addition" cause="unknown"
									rend="erasure">s</rdg>
								<rdg wit="#Tu" varSeq="2" type="lem" cause="correction" hand="#u"/>
							</app>ita et tecum sum</q></title>
				</item>
				<item n="5">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>3.14 igitur
								egressus est populus</citedRange></bibl><num>V</num></ref>
					<title>Iubente domino siccauit alueus iordanis <app>
							<lem>transeunte</lem>
							<rdg wit="#A" type="substantive" subtype="adiaphoric" cause="seriesA"
								>euntis</rdg>
						</app> israhel</title>
				</item>
				<item n="6">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>4.1 quibus
								transgressis</citedRange></bibl><num>VI</num></ref>
					<title>Duodecim <app>
							<lem>electi lapides</lem>
							<rdg wit="#A" type="transposition" cause="seriesA">lapides electi</rdg>
						</app>
						<app>
							<lem>leuati sunt</lem>
							<rdg wit="#A" type="omssion" cause="seriesA"/>
						</app> de iordanis alueo <app>
							<lem>a duodecim uiris de duodecim tribubus quos posuit iosue in
								galgalis</lem>
							<rdg wit="#A" type="omission" cause="seriesA"/>
						</app><app>
							<lem>pro commemoratione</lem>
							<rdg wit="#A" type="maior" subtype="adiaphoric" cause="seriesA">ob
								commemorationem</rdg>
						</app> futuri temporis <app>
							<lem>reuersusque est fluuius ad cursum suum et ascendit populus de
								iordanne decimo mensis prima die</lem>
							<rdg wit="#A" type="omission" cause="seriesA"/>
						</app></title>
				</item>
				<item n="7">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>5.1 postquam
								ergo audierunt</citedRange></bibl><num>VII</num></ref>
					<title>Introeunte israhel terram chanaan territi sunt cuncti reges</title>
				</item>
				<item n="8">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>5.2 eo tempore
								ait Dominus</citedRange></bibl><num>VIII</num></ref>
					<title>Haec autem causa est secundae circumcisionis</title>
				</item>
				<item n="9">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>5.9 dixitque
								Dominus ad Iosue</citedRange></bibl><num>VIIII</num></ref>
					<title>Hucusque comederunt manna</title>
				</item>
				<item n="10">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>5.13 cum autem
								esset Iosue</citedRange></bibl><num>X</num></ref>
					<title>Ostendit se angelus domini iosue qui dixit <q type="spoken">princeps
							exercitus domini sum</q></title>
				</item>
				<item n="11">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>6.1 Iericho
								autem clausa</citedRange></bibl><num>XI</num></ref>
					<title>De obsidione uel subuersione muri hiericho</title>
				</item>
				<item n="12">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>6.25 in
								tempore illo imprecatus</citedRange></bibl><num>XII</num></ref>
					<title><app>
							<lem>Inpraecatio</lem>
							<rdg wit="#A" type="minor" cause="orthographic">imprecatio</rdg>
						</app> iosue</title>
				</item>
				<item n="13">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>7.1 filii
								autem Israel praevaricati</citedRange></bibl><num>XIII</num></ref>
					<title>Praeuaricatio populi</title>
				</item>
				<item n="14">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>8.1 dixit
								autem Dominus</citedRange></bibl><num>XIIII</num></ref>
					<title>Confortat dominus iosue ad <app>
							<lem>proeliandum</lem>
							<rdg wit="#A" type="minor" cause="orthographic">praeliandum</rdg>
						</app></title>
				</item>
				<item n="15">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>9.1 quibus
								auditis cuncti reges</citedRange></bibl><num>XV</num></ref>
					<title>Perturbatio regum</title>
				</item>
				<item n="16">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>9.3 at hi qui
								habitabant</citedRange></bibl><num>XVI</num></ref>
					<title>Simulatio gabaonitarum</title>
				</item>
				<item n="17">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>10.1 quae cum
								audisset</citedRange></bibl><num>XVII</num></ref>
					<title>Conglobati quinque reges contra iosue ascenderunt tunc imperauit soli et
						stetit spatium diei unius </title>
				</item>
				<item n="18">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>10.8 dixitque
								Dominus</citedRange></bibl><num>XVIII</num></ref>
					<title>Iuuante domino extincti sunt reges cum exercitu suo</title>
				</item>
				<item n="19">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>12.6 Moyses
								famulus Domini</citedRange></bibl><num>XVIIII</num></ref>
					<title>Ruben gad et dimidiae <app>
							<lem>tribui</lem>
							<rdg wit="#Tu" varSeq="1" type="minor" cause="grammatical" cert="low"
								>tribu?</rdg>
							<rdg wit="#Tu" varSeq="2" type="lem" cause="correction" hand="#m"
								rend="overstrike">tribui</rdg>
						</app> manasse terram sibi dari postulantes a moyse</title>
				</item>
				<pb facs="data/images/single/Tu_271v.jpeg" n="Tu_271v"/>
				<lb n="[Tu_271v]"/>
				<item n="20">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>12.7 hi sunt
								reges</citedRange></bibl><num>XX</num></ref>
					<title><app>
							<lem>Hii</lem>
							<rdg wit="#A" type="minor" cause="orthographic">hi</rdg>
						</app> sunt reges terrae quos percussit iosue et filii israhel</title>
				</item>
				<item n="21">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>13.1 Iosue
								senex provectaeque</citedRange></bibl><num>XXI</num></ref>
					<title>Diuidere terras populis hortatur dominus iosue</title>
				</item>
				<item n="22">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>14.6
								accesserunt itaque filii</citedRange></bibl><num>XXII</num></ref>
					<title>Promissum repetit chaleb montem in quo hebron hic legis adam
						situm</title>
				</item>
				<item n="23">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>15.1 igitur
								sors filiorum</citedRange></bibl><num>XXIII</num></ref>
					<title><app>
							<lem>Possessio filiorum iudae per sortem et quia gebuseum habitatorem
								hierusalem non potuerunt filii iuda delere sed habitauit cum eis
								usque in presentem diem</lem>
							<rdg wit="#A" type="substantive" subtype="adiaphoric" cause="seriesA"
								>sors iudae</rdg>
						</app>
					</title>
				</item>
				<item n="24">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>16.1 cecidit
								quoque sors</citedRange></bibl><num>XXIIII</num></ref>
					<title><app>
							<lem>Possessio filiorum ioseph efraim et manasse per sortem et quia
								chananeum qui habitabat in gazer non potuerunt filii ephraim delere
								sed habitauit cum eis usque in presentem diem tributarius et quia
								filiabus salphaad dedit iosue possessionem iuxta imperium domini in
								medio fratrum patris earum</lem>
							<rdg wit="#A" type="substantive" subtype="adiaphoric" cause="seriesA"
								>sors filiorum ioseph ephraim et manasse</rdg>
						</app></title>
				</item>
				<item n="25">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>17.14
								locutique sunt filii</citedRange></bibl><num>XXV</num></ref>
					<title>Filii ioseph <app>
							<lem>petent</lem>
							<rdg wit="#A" type="minor" cause="grammatical">petunt</rdg>
						</app> sibi augmentari funiculum a iosue quibus ait <q type="spoken"
							>ascendite in montem et succidite siluam et mundate uobis ad habitandum
							spatia </q></title>
				</item>
				<item n="26">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>18.1
								congregatique sunt omnes</citedRange></bibl><num>XXVI</num></ref>
					<title>Congregatique sunt omnes filii israhel in silo</title>
				</item>
				<item n="27">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>18.8 cumque
								surrexissent viri</citedRange></bibl><num>XXVII</num></ref>
					<title>Destinantur <app>
							<lem>uiri</lem>
							<rdg wit="#Tu" varSeq="1" type="lem" rend="erasure" cert="low"
								>uir*</rdg>
							<rdg wit="#Tu" varSeq="2" type="minor"
								cause="grammatical_falseEmendation" hand="#u" cert="low">uir</rdg>
						</app> ad <app>
							<lem>discribendam</lem>
							<rdg wit="#A" type="minor" cause="orthographic">describendam</rdg>
						</app> terram reuersique <app>
							<lem>discriptionem</lem>
							<rdg wit="#A" type="minor" cause="orthographic">descriptionem</rdg>
						</app> tradunt iosue qui misit sortes coram domino in silo diuisitque terram
						filiis israhel in septem partes</title>
				</item>
				<item n="28">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>20.1 et
								locutus est dominus</citedRange></bibl><num>XXVIII</num></ref>
					<title>Urbes fugitiuorum</title>
				</item>
				<item n="29">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>21.1
								accesseruntque principes</citedRange></bibl><num>XXVIIII</num></ref>
					<title>Urbes leuitarum</title>
				</item>
				<item n="30">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>21.42 dataque
								est ab eo</citedRange></bibl><num>XXX</num></ref>
					<title>Post bellorum turbines data est et requies a domino</title>
				</item>
				<item n="31">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>22.10 cumque
								venissent</citedRange></bibl><num>XXXI</num></ref>
					<title>Inconsulta re facta a tribu ruben altare <app>
							<lem>inmense</lem>
							<rdg wit="#A" type="minor" cause="orthographic">inmensae</rdg>
						</app> magnitudinis</title>
				</item>
				<item n="32">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>23.1 evoluto
								autem</citedRange></bibl><num>XXXII</num></ref>
					<title>Replicat a principio iosue cuncta israheli cum obtestatione ne discedant
						a praeceptis domini <app>
							<lem>adpropinquante</lem>
							<rdg wit="#A" type="minor" cause="orthographic">appropinquante</rdg>
						</app>die obitus sui</title>
				</item>
				<item n="33">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>24.1
								congregavitque Iosue</citedRange></bibl><num>XXXIII</num></ref>
					<title>Unde natus sit abraham uel ubi perductus item congregatis cum pacto
						obtestationis adloquitur eos iosue</title>
				</item>
				<item n="34">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>This capitulum
								has no corresponding chapter number throughout the text of Iosue in
								Tu; it should probably have fallen around Ios
							24.22.</citedRange></bibl><num>XXXIIII</num></ref>
					<title><app>
							<lem>Congregatum israhel iosue sub pacto obtestationis adloquitur et
								scribens uerba sua in uolumine tulit lapidem grandem et posuit eum
								supter quercum in testimonio</lem>
							<rdg wit="#A" type="omission" cause="seriesA"/>
						</app></title>
				</item>
				<item n="35">
					<ref type="parallelPassage"><bibl><title>Iosue</title><citedRange>24.29 et post
								haec mortuus est Iosue</citedRange></bibl><num>XXXV</num></ref>
					<title><app>
							<lem>Mortuus est iosue centum decem annorum et sepultus est in
								possessione sua in monte ephraim ossa quoque ioseph quae tulerant
								filii israhel de aegypto sepelierunt in sichem in partem agri quem
								emerat iacob a filiis emmor centum nouellis ouibus nam et eleazar
								filius aaron mortuus est et sepelierunt eum in gabaath in monte
								efraim</lem>
							<rdg wit="#A" type="omission" cause="seriesA"/>
						</app></title>
				</item>
			</list>
